# Normalize all text files to LF in the repo so prettier's format:check
# (endOfLine: "lf") passes on Linux CI regardless of Windows/OneDrive CRLF
# in the working tree.
* text=auto eol=lf

# Binary assets must never be line-ending normalized.
*.png  -text
*.jpg  -text
*.jpeg -text
*.gif  -text
*.ico  -text
*.pdf  -text
*.woff  -text
*.woff2 -text
